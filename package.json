{
  "name": "sotiras-backend",
  "version": "1.0.0",
  "description": "Sotiras backend",
  "type": "module",
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "npm run build && node dist/main.js",
    "build:clean": "rm -rf dist",
    "build": "nest build",
    "build:watch": "nest build --watch",
    "migration:generate": "npx typeorm migration:generate -d dist/config/database/dataSource.js src/config/database/migrations/$npm_config_name",
    "migration:create": "npx typeorm migration:create src/config/database/migrations/$npm_config_name",
    "migration:run": "npx typeorm migration:run -d dist/config/database/dataSource.js",
    "migration:revert": "npx typeorm migration:revert -d dist/config/database/dataSource.js",
    "migration:drop": "npx typeorm schema:drop -d dist/config/database/dataSource.js",
    "migration:sync": "npx typeorm schema:sync -d dist/config/database/dataSource.js",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@fastify/static": "^8.1.1",
    "@nestjs/common": "^11.0.12",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.12",
    "@nestjs/platform-fastify": "^11.0.12",
    "@nestjs/swagger": "^11.1.0",
    "@nestjs/typeorm": "^11.0.0",
    "axios": "^1.8.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ethers": "^6.13.5",
    "fastify": "^4.0.0",
    "pg": "^8.10.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "typeorm": "^0.3.17"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^11.0.12",
    "@types/axios": "^0.14.4",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.40.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0",
    "ts-loader": "^9.4.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  }
}
